# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
.next/
out/
.turbo/

# Convex
.convex/

# Env / secrets (BYOK keys live here — never commit)
.env
.env.local
.env.*.local
local/.env

# Python services
__pycache__/
*.pyc
.venv/
venv/
services/**/.venv/

# Logs & OS
*.log
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
.idea/

# Generated assets / render output
local/output/
services/**/output/

# Stray scratch file (sandbox couldn't unlink; safe to delete on Windows)
.trunctest
**/.trunctest

# Compiled siblings in the Convex source dir (Convex bundles .ts; never commit
# compiled .js next to .ts — it breaks `convex dev` with duplicate outputs).
/packages/convex/convex/*.js
/packages/convex/convex/*.js.map
/packages/convex/convex/lib/*.js
/packages/convex/convex/lib/*.js.map

# Cowork automation kit (runtime — keep source, ignore generated/secrets)
automation/local/.env
automation/local/output/
automation/local/.data/
