# ─────────────────────────────────────────────────────────────
# Interior Design Platform — environment template
# Copy to `.env` (root) for shared values, and `local/.env` for the
# local runner. NEVER commit real keys. (.env is gitignored.)
# ─────────────────────────────────────────────────────────────

# ── AI provider ──────────────────────────────────────────────
# The LOCAL runner reads keys from here (local/.env).
# The WEB app's interactive AI is BYOK (web users enter their own key in
# Settings, stored encrypted in Convex). BUT backend automations that have no
# user in context — e.g. the WhatsApp lead intake — use a STUDIO SYSTEM KEY:
# set ANTHROPIC_API_KEY in the Convex deployment env (not committed).
AI_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_MODEL=gpt-4o

# ── Convex backend ───────────────────────────────────────────
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ── Encryption (server-side BYOK key vault) ──────────────────
# 32-byte base64 key used to encrypt user-supplied API keys at rest.
KEY_VAULT_SECRET=

# ── Heavy compute services (compute plane) ───────────────────
RENDER_SERVICE_URL=http://localhost:8001
CAD_SERVICE_URL=http://localhost:8002
TAKEOFF_SERVICE_URL=http://localhost:8003
# GPU AI render (pick one provider)
REPLICATE_API_TOKEN=
FAL_KEY=

# ── Indonesia integrations ───────────────────────────────────
# Payments
MIDTRANS_SERVER_KEY=
XENDIT_SECRET_KEY=
# WhatsApp (lead intake + notifications) — set these in the Convex deployment env
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=        # any string you choose; must match the Meta webhook config
