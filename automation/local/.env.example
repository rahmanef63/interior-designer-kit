# Copy this file to `.env` and fill in your key. The CLI loads it automatically.

# Required: your Anthropic API key (used by both engines).
ANTHROPIC_API_KEY=

# Optional: the folder the agent reads from and writes to.
# Defaults to the current working directory. Put inputs in `inbox/` inside it;
# the agent writes deliverables to `output/` and records to `.data/`.
# AUTOMATION_WORKSPACE=
